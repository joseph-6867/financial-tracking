# Created from .env.example by GitHub Copilot

# --- SUPABASE SETTINGS ---
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# --- JWT SETTINGS ---
# Replace the JWT secret with a strong random value in production
JWT_SECRET_KEY="replace-with-a-strong-random-secret"
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- SMTP EMAIL SETTINGS (optional) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
## Set your SMTP account email (e.g. yourname@gmail.com)
SMTP_EMAIL='your-email@gmail.com'
# Set your SMTP password here. For Gmail, use an App Password (16-character)
# For security, you may leave this blank and set the env var in your OS/CI instead.
SMTP_PASSWORD='your-app-password'

# --- OAUTH PROVIDER CONFIG (optional) ---
# Fill these if you enable OAuth provider flows (Google, GitHub).
# Keep them empty for local/manual token paste flow.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
